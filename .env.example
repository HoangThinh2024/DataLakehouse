# ============================================================
# DataLakehouse – environment configuration example
# ============================================================
# Copy this file to .env and update values for your environment.
# Never commit the actual .env file containing real credentials.
# ============================================================

# ─────────────────────────────────────────────────────────
# STORAGE LAYER
# ─────────────────────────────────────────────────────────

# PostgreSQL 17
POSTGRES_DB=datalakehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432

# RustFS (S3-compatible object storage)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_API_PORT=19000
RUSTFS_CONSOLE_PORT=19001
RUSTFS_CORS_ALLOWED_ORIGINS=http://localhost:19000
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=http://localhost:19001
RUSTFS_BUCKET=nocodb

# ClickHouse (OLAP analytics)
CLICKHOUSE_DB=analytics
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# ─────────────────────────────────────────────────────────
# PROCESSING LAYER
# ─────────────────────────────────────────────────────────

# Mage.ai
MAGE_PORT=6789

# Great Expectations
GE_PORT=8888

# ─────────────────────────────────────────────────────────
# SERVING LAYER
# ─────────────────────────────────────────────────────────

# Adminer
ADMINER_PORT=8080

# NocoDB
NOCODB_PORT=8081

# Metabase
METABASE_PORT=3000

# ─────────────────────────────────────────────────────────
# REPORTING LAYER
# ─────────────────────────────────────────────────────────

# Apache Superset
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=your-secret-key-change-in-production

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────
# INFRASTRUCTURE
# ─────────────────────────────────────────────────────────

# Nginx Proxy Manager
NPM_ADMIN_PORT=81
